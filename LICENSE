@startuml
!theme plain
skinparam componentStyle uml2

' --- La magie du style "Dessiné à la main" ---
skinparam handwritten true

' Ajustement des espacements pour éviter les chevauchements
skinparam nodesep 80
skinparam ranksep 100
skinparam defaultTextAlignment center

title Architecture de facturation : Monde Natif (AA) vs Monde Historique (Shadow)

' --- Définition des acteurs ---
actor "Batch Nuit\n(COB)" as sys
actor "Canaux / API" as api
actor "Conseiller" as user

' --- 1. Origines des transactions ---
package "Origines des Opérations (Déclencheurs)" {
    component "Modules Historiques / Spécifiques\n(FT, DC, TT, ACR...)" as Legacy #E8F8F5
    component "Opérations Natives AA\n(Facturation, Agios...)" as Natif #E8F8F5
}

' --- 2. Cœur de tarification ---
package "Core Banking : Architecture Arrangement (AA)" #F9EBEA {
    component "Activité\n(AA.ACTIVITY)" as Activity #FFFFFF
    component "Arrangement\n(Contrat Client)" as Arrangement #FFFFFF
    component "Produit\n(Règles Tarifaires)" as Product #FFFFFF
    database "Compte\n(ACCOUNT)" as Account #FFFFFF
}

' --- 3. Réglementation et Comptabilité ---
package "Exécution & Réglementation" {
    component "FRMB\n(Écrêtement Murcef)" as FRMB #FCF3CF
    
    database "Ledger Comptable" #EAEDED {
        component "STMT.ENTRY\n(Mouvement Client)" as STMT #FFFFFF
        component "CATEG.ENTRY\n(P&L Banque)" as CATEG #FFFFFF
    }
}

' --- Routage des Acteurs ---
sys ---> Natif : "Déclenche\n(Échéances)"
api ---> Legacy : "Soumet\n(Virement FT)"
user ---> Legacy : "Saisit\n(Frais ACR)"

' --- La dichotomie Shadow vs Natif ---
' Utilisation de flèches plus longues pour laisser respirer le texte
Legacy ...down...> Activity : "**Génère implicitement**\n(Shadow Activity)"
Natif ---down---> Activity : "**Crée directement**\n(Événement Natif)"

' --- Mécanique AA ---
Product -right-> Arrangement : "Instancie"
Activity ---down---> Arrangement : "Sollicite le contrat"

' --- Contrôle et Comptabilisation ---
Arrangement ---down---> FRMB : "Vérifie les plafonds\navant débit"
FRMB ---down---> STMT : "Crée ligne comptable\n(Montant facturé)"
FRMB ---right---> CATEG : "Crée contrepartie"

STMT -left-> Account : "Met à jour\nle solde"

' --- Notes explicatives ---
note top of Legacy
  Les anciens modules parlent leur 
  propre langage. Le framework AA
  génère une activité "fantôme" 
  pour faire la traduction.
end note

note top of Natif
  Aucune traduction nécessaire.
  L'événement généré est 
  directement une Activité AA.
end note

note bottom of STMT
  Clé de jointure pour les Transactions: TRANS.REFERENCE
  (commence par FT... ou AAA...)
end note

@enduml
